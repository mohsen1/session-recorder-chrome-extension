{
  "name": "session-recorder-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chrome extension that records rich, multi-modal web-app sessions (interactions, full network traffic, screenshots, voice, annotations, files) and exports an LLM-optimized report.",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "compile:e2e": "tsc -p e2e/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "wxt build && playwright test",
    "test:e2e:headed": "wxt build && HEADED=1 playwright test",
    "og": "node design/generate-og.mjs",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "fabric": "^6.9.1",
    "fflate": "^0.8.2",
    "idb": "^8.0.0",
    "lucide-react": "^1.23.0",
    "marked": "^18.0.5",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.0.287",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@wxt-dev/module-react": "^1.1.3",
    "jsdom": "^25.0.1",
    "typescript": "~5.6.3",
    "vitest": "^2.1.8",
    "wxt": "^0.19.13"
  },
  "packageManager": "pnpm@11.6.0"
}
